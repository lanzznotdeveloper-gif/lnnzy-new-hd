{
  "manifest_version": 3,
  "name": "Senzeyn X Tiktok",
  "version": "5.5",
  "description": "Tools For High Quality Uploads on Tiktok",
  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "scripting",
    "activeTab",
    "storage",
    "alarms",
    "tabs"
  ],
  "host_permissions": [
    "*://*.tiktok.com/tiktokstudio/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "js": [
        "core/load.js",
        "core/overlay.js",
        "core/main.js"
      ],
      "matches": [
        "*://*.tiktok.com/tiktokstudio/*"
      ],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "icons": {
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "action": {
    "default_popup": "index.html",
    "default_title": "Senzeyn Extension",
    "default_icon": {
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "matches": [
        "https://www.tiktok.com/*"
      ],
      "resources": [
        "ui/popup.js",
        "core/overlay.js",
        "manifest.json",
        "ui/index.js",
        "index.html",
        "encoder/encoder-frame.html",
        "encoder/encoder-frame.js",
        "encoder/core/*",
        "encoder/ffmpeg/*"
      ]
    }
  ],
  "cross_origin_embedder_policy": {
    "value": "require-corp"
  },
  "cross_origin_opener_policy": {
    "value": "same-origin"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; worker-src 'self'; img-src 'self' blob: data:; media-src 'self' blob:"
  }
}